# ============================================================
# Atlassian MCP Guardrails — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Required: Atlassian Credentials ---
# Your Atlassian Cloud base URL (e.g. https://yourcompany.atlassian.net)
JIRA_BASE_URL=https://your-instance.atlassian.net

# The email address associated with your Atlassian account
JIRA_EMAIL=your-email@company.com

# Your Atlassian API token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_TOKEN=your-atlassian-api-token

# --- Optional: Confluence URL ---
# Defaults to JIRA_BASE_URL if not set (correct for Atlassian Cloud).
# Set this only if your Confluence is on a different host than Jira.
# CONFLUENCE_BASE_URL=https://your-instance.atlassian.net

# --- Default Scope (auto-injected when query has no project/space) ---
# Set to your program's Jira project keys (comma-separated, no spaces).
# Queries without an explicit project filter will be scoped to these automatically.
# Leave empty to disable auto-scoping (queries go to the full Jira instance).
JIRA_DEFAULT_PROJECTS=

# Set to your program's Confluence space keys (comma-separated, no spaces).
# Queries without an explicit space filter will be scoped to these automatically.
# Leave empty to disable auto-scoping.
CONFLUENCE_DEFAULT_SPACES=

# --- Allowlist (hard enforcement — queries outside this scope are rejected) ---
# Set to the same values as DEFAULT, or a subset.
# If non-empty, any query that does not reference one of these projects/spaces
# will be rejected with a ScopeViolationError.
# Leave empty to allow any project/space (advisory mode only).
JIRA_ALLOWED_PROJECTS=
CONFLUENCE_ALLOWED_SPACES=

# --- Rate Limiting and Result Caps ---
# Default number of results returned per search call
MAX_RESULTS_PER_REQUEST=50

# Absolute maximum results; callers cannot exceed this even by passing a larger value
MAX_RESULTS_HARD_CAP=200

# Maximum number of Atlassian API calls allowed per single tool invocation
MAX_API_CALLS_PER_REQUEST=20

# Minimum delay in milliseconds between API calls within one tool invocation
REQUEST_DELAY_MS=100

# HTTP request timeout in seconds
HTTP_TIMEOUT=30

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# Atlassian MCP Guardrails — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Required: Atlassian Credentials ---
# Insulet Atlassian Cloud base URL
JIRA_BASE_URL=https://insulet.atlassian.net

# Your Insulet email address (Atlassian account)
JIRA_EMAIL=your-email@insulet.com

# Atlassian API token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_TOKEN=your-atlassian-api-token

# --- Optional: Confluence URL ---
# Insulet uses a custom Confluence domain that resolves to insulet.atlassian.net/wiki
CONFLUENCE_BASE_URL=https://insulet.atlassian.net/wiki

# --- Default Scope — all 6 NextGen projects / your Confluence spaces ---
# Auto-injected when a query has no explicit project/space clause (scope="default")
JIRA_DEFAULT_PROJECTS=NGCRMI,NGONDL,NGASIM,NGPSTE,NGOMCT,NGMC

# Resolved from https://confluence.prod.insulet.com/wiki/spaces (Your spaces):
# DGB Gibraltar, Electronic Systems, iOS Platform ART, Moonshot, Som Balakrushnan,
# NextGen CRM (U.S.), MuleSoft Integrations, Enterprise-SRE, Atlassian Support, CC_International
CONFLUENCE_DEFAULT_SPACES=AJST,AS,CCPROC,DGBG,ESG,MOON,Mule,NASFL,ensre

# --- Priority Scope (Phase 1) — projects + label/fix-version filter ---
# Used when scope="priority" (the default for jira_search).
# Narrows results to NextGen program work before expanding to the full default scope.
JIRA_PRIORITY_PROJECTS=NGCRMI,NGONDL,NGASIM,NGPSTE,NGOMCT,NGMC
JIRA_PRIORITY_LABELS=2026Q2,NGPI4,NGPI3,NextGen,PRJ0717,PodderCentral,Team3
JIRA_PRIORITY_FIX_VERSIONS=Project Infinity SOW MVP,Project Infinity Persona Release 2

# --- Expanded Scope (Phase 2) — broader label/fix-version set ---
# Used when scope="expanded". Adds NGPI2, OrgSync, PI2_OS_Sprint3 and Persona Release 1.
JIRA_EXPANDED_LABELS=2026Q2,NGPI4,NGPI3,NGPI2,NextGen,PRJ0717,PodderCentral,Team3,OrgSync,PI2_OS_Sprint3
JIRA_EXPANDED_FIX_VERSIONS=Project Infinity SOW MVP,Project Infinity Persona Release 1,Project Infinity Persona Release 2

# --- Allowlist (hard enforcement — queries outside this scope are rejected) ---
# Leave empty to allow any project/space (advisory mode only).
JIRA_ALLOWED_PROJECTS=
CONFLUENCE_ALLOWED_SPACES=

# --- Rate Limiting and Result Caps ---
MAX_RESULTS_PER_REQUEST=50
MAX_RESULTS_HARD_CAP=200
MAX_API_CALLS_PER_REQUEST=20
REQUEST_DELAY_MS=100
HTTP_TIMEOUT=30

# --- Text Field Caps (0 = unlimited) ---
# Controls how much of the description and acceptance criteria is returned by
# jira_get_issue and jira_search. Set to 0 for full fidelity (recommended for
# deep-retrieval pipeline runs). Legacy default was 500/1000 chars.
DESCRIPTION_MAX_CHARS=0
AC_MAX_CHARS=0

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
